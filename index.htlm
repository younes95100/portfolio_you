    <!-- Section Veille (WiFi 7) -->
    <section id="veille" class="py-32 px-10 bg-white text-black">
        <div class="max-w-6xl mx-auto">
            <h2 class="text-6xl font-bold mb-16 border-b-8 border-black pb-4 reveal">VEILLE TECHNOLOGIQUE</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-20">
