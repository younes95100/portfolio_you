                                <span class="text-xs opacity-60">Agrégation de bandes 2.4, 5 et 6 GHz</span>
                            </div>
                        </li>
                        <li class="flex items-center gap-4">
                            <i class="fa-solid fa-gauge-high text-2xl text-green-400"></i>
                            <div>
                                <span class="block font-bold">CANAUX 320 MHZ</span>
                                <span class="text-xs opacity-60">Doublement de la bande passante par rapport au WiFi 6E</span>
                            </div>
                        </li>
                        <li class="flex items-center gap-4">
                            <i class="fa-solid fa-microchip text-2xl text-purple-400"></i>
                            <div>
                                <span class="block font-bold">MODULATION 4096-QAM</span>
                                <span class="text-xs opacity-60">Efficacité spectrale augmentée de 20%</span>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
